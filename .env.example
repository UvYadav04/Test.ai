OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
DEFAULT_LLM_PROVIDER=
DEFAULT_MODEL=

# Provider the orchestrator/document agents fall back to if their primary provider's call fails
# outright (client couldn't be built, e.g. missing credentials) or transiently errors after
# retries are exhausted (see llm_provider/retry_client.py) - NOT used for rate limits, which
# llm_provider/errors.py deliberately treats as non-retryable (see its comment for why). Must be
# a DIFFERENT provider than whichever agent's *_PROVIDER setting is active, or the fallback is a
# no-op (LLMProvider.get_client() detects primary==fallback and skips wrapping entirely) - e.g.
# if ORCHESTRATOR_PROVIDER=groq, leaving this at the default "groq" gives zero real redundancy.
FALLBACK_LLM_PROVIDER=groq

# Per-agent model overrides - each agent falls back to DEFAULT_LLM_PROVIDER/DEFAULT_MODEL if unset.
TABULAR_AGENT_PROVIDER=groq
TABULAR_AGENT_MODEL=llama-3.1-8b-instant

DOCUMENT_AGENT_PROVIDER=gemini
DOCUMENT_AGENT_MODEL=gemini-2.5-flash

ORCHESTRATOR_PROVIDER=gemini
ORCHESTRATOR_MODEL=gemini-2.5-flash

CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# PDFIngestor parses PDFs via LlamaParse's cloud API instead of running docling's
# CPU-bound layout/table-structure pipeline locally - see ingestion/file_types/pdf/
# llamaparse_client.py's docstring. Get a key at https://cloud.llamaindex.ai
LLAMAPARSE_API_KEY=

RERANKER_MODEL=
# Reranker now calls the Hugging Face Inference API (no local torch model) -
# needs a token: https://huggingface.co/settings/tokens
HF_API_TOKEN=

AGENT_LOG_LEVEL=

# --- Langfuse (LLM call tracing - see llm_provider/langfuse_wrapper.py) ---
# In docker-compose.yml LANGFUSE_HOST is already set via `environment:`
# (points at the langfuse-web service on the compose network) - only needed
# here if running worker_service as a bare process outside docker compose.
#
# LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY must be the SAME values as
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY / LANGFUSE_INIT_PROJECT_SECRET_KEY in the
# root .env.example (that's what auto-creates a project with these exact
# keys on Langfuse's first boot - see the comment there for why). If you'd
# rather skip auto-provisioning and sign up through the Langfuse UI
# (http://localhost:3000) manually instead, leave the root .env's
# LANGFUSE_INIT_* block blank and paste the keys the UI generates here
# instead. Either way: every LLM call made through llm_provider.LLMProvider
# is traced automatically once these are set; leave blank to disable
# tracing entirely (falls back to no-op).
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=